generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  plan        Plan         @default(STARTER)
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  automations Automation[]
  bookings    Booking[]
  brokers     Broker[]
  leads       Lead[]
  projects    Project[]
  users       User[]
  payments    Payment[]
}

model User {
  id            String      @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String
  name          String
  phone         String?
  role          UserRole
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  activities    Activity[]
  assignedLeads Lead[]      @relation("AssignedAgent")
  siteVisits    SiteVisit[]
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Project {
  id             String        @id @default(cuid())
  tenantId       String
  name           String
  location       String
  city           String?
  state          String?
  projectType    ProjectType
  status         ProjectStatus @default(ACTIVE)
  reraNumber     String?
  possessionDate DateTime?
  amenities      String[]      @default([])
  images         String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  leads          Lead[]
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  towers         Tower[]

  @@index([tenantId])
}

model Tower {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  totalFloors Int
  project     Project @relation(fields: [projectId], references: [id])
  units       Unit[]
}

model Unit {
  id                String     @id @default(cuid())
  towerId           String
  tenantId          String
  unitNumber        String
  floor             Int
  bhkType           String
  carpetArea        Float
  superArea         Float?
  facing            String?
  basePrice         Float
  totalPrice        Float
  status            UnitStatus @default(AVAILABLE)
  floorPlanUrl      String?
  reservedUntil     DateTime?
  reservedForLeadId String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  booking           Booking?
  tower             Tower      @relation(fields: [towerId], references: [id])

  @@index([towerId, status])
}

model Lead {
  id                 String             @id @default(cuid())
  tenantId           String
  projectId          String?
  assignedToId       String?
  name               String
  phone              String
  email              String?
  budgetMin          Float?
  budgetMax          Float?
  bhkPreference      String[]           @default([])
  source             LeadSource
  sourceName         String?
  stage              PipelineStage      @default(NEW_LEAD)
  priority           Priority           @default(NORMAL)
  tags               String[]           @default([])
  notes              String?
  isActive           Boolean            @default(true)
  firstContactedAt   DateTime?
  lastActivityAt     DateTime?
  nextFollowUpAt     DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  brokerId           String?
  whatsappOptOut     Boolean            @default(false)
  aiScore            Float?
  aiScoreLabel       String?
  aiHandoffRequested Boolean            @default(false)
  activities         Activity[]
  aiCalls            AiCall[]
  aiInteractions     AiInteraction[]
  aiRecommendations  AiRecommendation[]
  booking            Booking?
  assignedTo         User?              @relation("AssignedAgent", fields: [assignedToId], references: [id])
  broker             Broker?            @relation(fields: [brokerId], references: [id])
  project            Project?           @relation(fields: [projectId], references: [id])
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  siteVisits         SiteVisit[]

  @@index([tenantId, stage])
  @@index([tenantId, assignedToId])
  @@index([phone, tenantId])
}

model SiteVisit {
  id              String        @id @default(cuid())
  tenantId        String
  leadId          String
  agentId         String?
  scheduledAt     DateTime
  notes           String?
  outcome         VisitOutcome?
  outcomeNotes    String?
  followUpDate    DateTime?
  reminder24hSent Boolean       @default(false)
  reminder2hSent  Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  agent           User?         @relation(fields: [agentId], references: [id])
  lead            Lead          @relation(fields: [leadId], references: [id])

  @@index([tenantId])
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String
  userId      String?
  type        ActivityType
  description String
  metadata    Json         @default("{}")
  tenantId    String
  createdAt   DateTime     @default(now())
  lead        Lead         @relation(fields: [leadId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([tenantId])
}

model Broker {
  id            String       @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  email         String?
  reraNumber    String?
  firmName      String?
  referralCode  String       @unique
  commissionPct Float        @default(2.0)
  isActive      Boolean      @default(true)
  isApproved    Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  commissions   Commission[]
  leads         Lead[]

  @@index([tenantId])
}

model Booking {
  id          String        @id @default(cuid())
  tenantId    String
  leadId      String        @unique
  unitId      String        @unique
  tokenAmount Float
  totalAmount Float
  bookingDate DateTime      @default(now())
  status      BookingStatus @default(ACTIVE)
  documents   Json          @default("[]")
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lead        Lead          @relation(fields: [leadId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  unit        Unit          @relation(fields: [unitId], references: [id])
  commission  Commission?
  payments    Payment[]

  @@index([tenantId])
}

model Payment {
  id                String         @id @default(cuid())
  bookingId         String
  tenantId          String
  amount            Float
  dueDate           DateTime
  paidAt            DateTime?
  method            PaymentMethod?
  referenceNumber   String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  receiptUrl        String?
  status            PaymentStatus  @default(PENDING)
  createdAt         DateTime       @default(now())
  booking           Booking        @relation(fields: [bookingId], references: [id])
  tenant            Tenant         @relation(fields: [tenantId], references: [id])

  @@index([bookingId])
  @@index([tenantId])
}

model Commission {
  id         String           @id @default(cuid())
  bookingId  String           @unique
  brokerId   String
  amount     Float
  percentage Float
  status     CommissionStatus @default(PENDING)
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime         @default(now())
  booking    Booking          @relation(fields: [bookingId], references: [id])
  broker     Broker           @relation(fields: [brokerId], references: [id])
}

model Automation {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  description String?
  trigger     Json
  conditions  Json            @default("[]")
  actions     Json
  isEnabled   Boolean         @default(true)
  runCount    Int             @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  logs        AutomationLog[]

  @@index([tenantId])
}

model AutomationLog {
  id           String     @id @default(cuid())
  automationId String
  tenantId     String
  leadId       String?
  status       String
  output       Json       @default("{}")
  runAt        DateTime   @default(now())
  automation   Automation @relation(fields: [automationId], references: [id])

  @@index([automationId])
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  tenantId    String
  leadId      String
  direction   String
  message     String
  templateId  String?
  status      String   @default("SENT")
  waMessageId String?
  sentAt      DateTime @default(now())

  @@index([tenantId, leadId])
}

model AiInteraction {
  id           String      @id @default(cuid())
  tenantId     String
  leadId       String
  agentType    AiAgentType
  input        Json
  output       Json
  tokensUsed   Int         @default(0)
  durationMs   Int         @default(0)
  modelUsed    String?
  wasEscalated Boolean     @default(false)
  escalatedAt  DateTime?
  createdAt    DateTime    @default(now())
  lead         Lead        @relation(fields: [leadId], references: [id])

  @@index([tenantId, leadId])
  @@index([agentType])
}

model AiCall {
  id            String     @id @default(cuid())
  tenantId      String
  leadId        String
  status        CallStatus
  duration      Int        @default(0)
  recordingUrl  String?
  transcript    String?
  summary       String?
  extractedData Json       @default("{}")
  visitBooked   Boolean    @default(false)
  escalatedToId String?
  startedAt     DateTime   @default(now())
  endedAt       DateTime?
  lead          Lead       @relation(fields: [leadId], references: [id])

  @@index([tenantId, leadId])
}

model AiRecommendation {
  id         String   @id @default(cuid())
  tenantId   String
  leadId     String
  unitIds    String[]
  reasoning  String
  score      Float[]
  wasShown   Boolean  @default(false)
  wasClicked Boolean  @default(false)
  createdAt  DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id])

  @@index([tenantId, leadId])
}

model AiInsight {
  id        String   @id @default(cuid())
  tenantId  String
  type      String
  title     String
  body      String
  data      Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

enum Plan {
  STARTER
  GROWTH
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserRole {
  TENANT_ADMIN
  SALES_MANAGER
  SALES_AGENT
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  PLOTTED
  VILLA
}

enum ProjectStatus {
  ACTIVE
  SOLD_OUT
  ON_HOLD
  ARCHIVED
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  BOOKED
  SOLD
  BLOCKED
}

enum LeadSource {
  MANUAL
  WEBSITE
  FACEBOOK
  GOOGLE
  WHATSAPP
  PORTAL_99ACRES
  PORTAL_MAGICBRICKS
  BROKER
}

enum PipelineStage {
  NEW_LEAD
  CONTACTED
  INTERESTED
  VISIT_SCHEDULED
  VISIT_DONE
  NEGOTIATION
  BOOKING_DONE
  LOST
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ActivityType {
  CALL
  WHATSAPP
  EMAIL
  NOTE
  STAGE_CHANGE
  VISIT_SCHEDULED
  DOCUMENT_SENT
  SYSTEM
}

enum VisitOutcome {
  INTERESTED
  FOLLOW_UP
  NOT_INTERESTED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  FAILED
  REFUNDED
}

enum BookingStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  DISPUTED
}

enum PaymentMethod {
  ONLINE_RAZORPAY
  UPI
  NEFT_RTGS
  CHEQUE
  CASH
  DD
}

enum AiAgentType {
  SCORING
  WHATSAPP_CONVERSATION
  CALLING
  RECOMMENDATION
  ANALYTICS
  DISCOVERY
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  TRANSFERRED
}
