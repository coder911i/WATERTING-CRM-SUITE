generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  plan      Plan         @default(STARTER)
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  users       User[]
  projects    Project[]
  leads       Lead[]
  brokers     Broker[]
  bookings    Booking[]
  automations Automation[]
  towers      Tower[]
  units       Unit[]
  activities  Activity[]
  siteVisits  SiteVisit[]
  commissions Commission[]
  automationLogs AutomationLog[]
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String
  name          String
  phone         String?
  role          UserRole
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  assignedLeads Lead[]    @relation("AssignedAgent")
  activities    Activity[]
  siteVisits    SiteVisit[]
  @@unique([tenantId, email])
  @@index([tenantId])
}

model Project {
  id             String        @id @default(cuid())
  tenantId       String
  name           String
  location       String
  city           String?
  state          String?
  projectType    ProjectType
  status         ProjectStatus @default(PLANNING)
  reraNumber     String?
  possessionDate DateTime?
  amenities      String[]      @default([])
  images         String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  towers         Tower[]
  leads          Lead[]
  @@index([tenantId])
}

model Tower {
  id          String  @id @default(cuid())
  projectId   String
  tenantId    String
  name        String
  totalFloors Int
  project     Project @relation(fields: [projectId], references: [id])
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  units       Unit[]
  @@index([tenantId])
}

model Unit {
  id               String     @id @default(cuid())
  towerId          String
  tenantId         String
  unitNumber       String
  floor            Int
  bhkType          String
  carpetArea       Float
  superArea        Float?
  facing           String?
  basePrice        Float
  totalPrice       Float
  status           UnitStatus @default(AVAILABLE)
  floorPlanUrl     String?
  reservedUntil    DateTime?
  reservedForLeadId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  tower            Tower      @relation(fields: [towerId], references: [id])
  tenant           Tenant     @relation(fields: [tenantId], references: [id])
  booking          Booking?
  @@index([towerId, status])
  @@index([tenantId])
}

model Lead {
  id              String        @id @default(cuid())
  tenantId        String
  projectId       String?
  assignedToId    String?
  name            String
  phone           String
  email           String?
  budgetMin       Float?
  budgetMax       Float?
  bhkPreference   String[]      @default([])
  source          LeadSource
  sourceName      String?
  stage           PipelineStage @default(NEW)
  priority        Priority      @default(MEDIUM)
  tags            String[]      @default([])
  notes           String?
  isActive        Boolean       @default(true)
  firstContactedAt DateTime?
  lastActivityAt  DateTime?
  nextFollowUpAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  project         Project?      @relation(fields: [projectId], references: [id])
  assignedTo      User?         @relation("AssignedAgent", fields: [assignedToId], references: [id])
  activities      Activity[]
  siteVisits      SiteVisit[]
  brokerId        String?
  broker          Broker?       @relation(fields: [brokerId], references: [id])
  booking         Booking?
  whatsappOptOut  Boolean       @default(false)
  
  // AI Fields thresholds triggers layout managers
  aiScore           Float?
  aiScoreLabel      String?
  aiHandoffRequested Boolean @default(false)
  aiInteractions    AiInteraction[]
  aiCalls           AiCall[]
  aiRecommendations AiRecommendation[]

  @@index([tenantId, stage])
  @@index([tenantId, assignedToId])
  @@index([phone, tenantId])
}

model SiteVisit {
  id              String        @id @default(cuid())
  tenantId        String
  leadId          String
  agentId         String?
  scheduledAt     DateTime
  notes           String?
  outcome         VisitOutcome?
  outcomeNotes    String?
  followUpDate    DateTime?
  reminder24hSent Boolean       @default(false)
  reminder2hSent  Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  lead            Lead          @relation(fields: [leadId], references: [id])
  agent           User?         @relation(fields: [agentId], references: [id])
  @@index([tenantId])
}

model Activity {
  id          String       @id @default(cuid())
  tenantId    String
  leadId      String
  userId      String?
  type        ActivityType
  description String
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  lead        Lead         @relation(fields: [leadId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  @@index([leadId])
  @@index([tenantId])
}

model Broker {
  id             String           @id @default(cuid())
  tenantId       String
  name           String
  phone          String
  email          String?
  reraNumber     String?
  firmName       String?
  referralCode   String           @unique
  commissionPct  Float            @default(2.0)
  isActive       Boolean          @default(true)
  isApproved     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  leads          Lead[]
  commissions    Commission[]
  @@index([tenantId])
}

model Booking {
  id             String        @id @default(cuid())
  tenantId       String
  leadId         String        @unique
  unitId         String        @unique
  tokenAmount    Float
  totalAmount    Float
  bookingDate    DateTime      @default(now())
  status         BookingStatus @default(CONFIRMED)
  documents      Json          @default("[]")
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  lead           Lead          @relation(fields: [leadId], references: [id])
  unit           Unit          @relation(fields: [unitId], references: [id])
  payments       Payment[]
  paymentSchedules PaymentSchedule[]
  commission     Commission?
  @@index([tenantId])
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String
  amount            Float
  dueDate           DateTime
  paidAt            DateTime?
  method            PaymentMethod?
  referenceNumber   String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  receiptUrl        String?
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  booking           Booking       @relation(fields: [bookingId], references: [id])
  @@index([bookingId])
}

model PaymentSchedule {
  id            String        @id @default(cuid())
  bookingId     String
  tenantId      String
  installmentNo Int
  amount        Float
  dueDate       DateTime
  status        PaymentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id])
  @@index([bookingId])
  @@index([tenantId])
}

model Commission {
  id         String           @id @default(cuid())
  tenantId   String
  bookingId  String           @unique
  brokerId   String
  amount     Float
  percentage Float
  status     CommissionStatus @default(PENDING)
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime         @default(now())
  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  booking    Booking          @relation(fields: [bookingId], references: [id])
  broker     Broker           @relation(fields: [brokerId], references: [id])
  @@index([tenantId])
}

model Automation {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  trigger     AutomationTrigger
  conditions  Json      @default("[]")
  actions     AutomationAction[]
  isEnabled   Boolean   @default(true)
  runCount    Int       @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  logs        AutomationLog[]
  @@index([tenantId])
}

model AutomationLog {
  id           String    @id @default(cuid())
  tenantId     String
  automationId String
  leadId       String?
  status       String
  output       Json      @default("{}")
  runAt        DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  automation   Automation @relation(fields: [automationId], references: [id])
  @@index([automationId])
  @@index([tenantId])
}

model ClientPortalToken {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([tenantId, clientId])
}

model WhatsAppMessage {
  id          String    @id @default(cuid())
  tenantId    String
  leadId      String
  direction   String
  message     String
  templateId  String?
  status      String    @default("SENT")
  waMessageId String?
  sentAt      DateTime  @default(now())
  @@index([tenantId, leadId])
}

model AiInteraction {
  id           String      @id @default(cuid())
  tenantId     String
  leadId       String
  agentType    AiAgentType
  input        Json
  output       Json
  tokensUsed   Int         @default(0)
  durationMs   Int         @default(0)
  modelUsed    String?
  wasEscalated Boolean     @default(false)
  escalatedAt  DateTime?
  createdAt    DateTime    @default(now())
  lead         Lead        @relation(fields: [leadId], references: [id])
  @@index([tenantId, leadId])
  @@index([agentType])
}

model AiCall {
  id             String     @id @default(cuid())
  tenantId       String
  leadId         String
  status         CallStatus
  duration       Int        @default(0)
  recordingUrl   String?
  transcript     String?
  summary        String?
  extractedData  Json       @default("{}")
  visitBooked    Boolean    @default(false)
  escalatedToId  String?
  startedAt      DateTime   @default(now())
  endedAt        DateTime?
  lead           Lead       @relation(fields: [leadId], references: [id])
  @@index([tenantId, leadId])
}

model AiRecommendation {
  id           String   @id @default(cuid())
  tenantId     String
  leadId       String
  unitIds      String[]
  reasoning    String
  score        Float[]
  wasShown     Boolean  @default(false)
  wasClicked   Boolean  @default(false)
  createdAt    DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id])
  @@index([tenantId, leadId])
}

model AiInsight {
  id        String   @id @default(cuid())
  tenantId  String
  type      String
  title     String
  body      String
  data      Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([tenantId])
}

// ==========================================
// ENUMS
// ==========================================

enum Plan { 
  FREE 
  STARTER 
  GROWTH 
  ENTERPRISE 
}

enum TenantStatus { 
  ACTIVE 
  SUSPENDED 
  CANCELLED 
  TRIAL 
}

enum UserRole { 
  SUPER_ADMIN 
  ADMIN 
  MANAGER 
  AGENT 
  CLIENT 
}

enum ProjectType { 
  RESIDENTIAL 
  COMMERCIAL 
  MIXED_USE 
  PLOTTED 
  VILLA 
}

enum ProjectStatus { 
  PLANNING 
  UNDER_CONSTRUCTION 
  READY_TO_MOVE 
  COMPLETED 
}

enum UnitStatus { 
  AVAILABLE 
  RESERVED 
  BOOKED 
  SOLD 
  BLOCKED 
}

enum LeadSource { 
  WEBSITE 
  FACEBOOK 
  INSTAGRAM 
  GOOGLE_ADS 
  PORTAL_99ACRES 
  PORTAL_MAGICBRICKS 
  PORTAL_HOUSING 
  REFERRAL 
  BROKER 
  WALK_IN 
  COLD_CALL 
  OTHER 
}

enum PipelineStage { 
  NEW 
  CONTACTED 
  INTERESTED 
  SITE_VISIT_SCHEDULED 
  SITE_VISIT_DONE 
  NEGOTIATION 
  BOOKED 
  LOST 
}

enum Priority { 
  LOW 
  MEDIUM 
  HIGH 
  URGENT 
}

enum ActivityType { 
  CALL 
  EMAIL 
  WHATSAPP 
  SITE_VISIT 
  NOTE 
  MEETING 
  FOLLOW_UP 
}

enum VisitOutcome { 
  INTERESTED 
  NOT_INTERESTED 
  NEEDS_FOLLOWUP 
  BOOKED 
  CANCELLED 
}

enum PaymentStatus { 
  PENDING 
  PAID 
  OVERDUE 
  WAIVED 
}

enum BookingStatus { 
  DRAFT 
  CONFIRMED 
  CANCELLED 
}

enum CommissionStatus { 
  PENDING 
  APPROVED 
  PAID 
  DISPUTED 
}

enum AutomationTrigger { 
  LEAD_CREATED 
  STAGE_CHANGED 
  SITE_VISIT_SCHEDULED 
  SITE_VISIT_COMPLETED 
  BOOKING_CREATED 
  PAYMENT_DUE 
}

enum AutomationAction { 
  SEND_EMAIL 
  SEND_WHATSAPP 
  CREATE_ACTIVITY 
  ASSIGN_AGENT 
  MOVE_STAGE 
  SEND_NOTIFICATION 
}

enum PaymentMethod {
  ONLINE_RAZORPAY
  UPI
  NEFT_RTGS
  CHEQUE
  CASH
  DD
}

enum AiAgentType { 
  SCORING 
  WHATSAPP_CONVERSATION 
  CALLING 
  RECOMMENDATION 
  ANALYTICS 
  DISCOVERY 
}

enum CallStatus { 
  INITIATED 
  RINGING 
  IN_PROGRESS 
  COMPLETED 
  FAILED 
  NO_ANSWER 
  TRANSFERRED 
}
